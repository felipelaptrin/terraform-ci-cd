{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "America/Sao_Paulo",
  "enabledManagers": [
    "mise",
    "terraform",
    "github-actions"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "mise",
        "terraform",
        "github-actions"
      ],
      "groupName": "dependencies",
      "schedule": [
        "on monday"
      ]
    }
  ]
}
